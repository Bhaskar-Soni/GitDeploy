# GitDeploy Environment Configuration
# ─── SECURITY NOTICE ────────────────────────────────────
# [!] IMPORTANT: Copy this file to .env before starting.
# [!] For production: change the SECRET_KEY and 
#     DEFAULT_ADMIN_PASSWORD variables below.
# ────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gitdeploy:gitdeploy@localhost:5432/gitdeploy
SYNC_DATABASE_URL=postgresql://gitdeploy:gitdeploy@localhost:5432/gitdeploy

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI Provider (configure one) ────────────────────────
# Supported: openai, anthropic, gemini, groq
# AI_PROVIDER=groq
# AI_API_KEY=your-api-key-here
# AI_MODEL=llama-3.3-70b-versatile

# ── Sandbox ─────────────────────────────────────────────
GITHUB_CLONE_DIR=/tmp/gitdeploy/repos
MAX_JOB_TIMEOUT_SECONDS=600
MAX_DB_PROVISION_TIMEOUT_SECONDS=60
MAX_REPO_SIZE_MB=500

# ── Security ────────────────────────────────────────────
# Default dev key works out of the box. For production, generate a new one:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=YLSdu_26pOrLhe9qtZrOPkiMHVJCjLqr_X-mVxWma_g=

# ── Authentication ──────────────────────────────────────
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=change-me-in-production
JWT_EXPIRY_HOURS=24

# ── DB Detection ────────────────────────────────────────
DB_DETECTION_CONFIDENCE_THRESHOLD=0.7
DB_AI_FALLBACK_CONFIDENCE_THRESHOLD=0.5

# ── CORS ────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173"]
